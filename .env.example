# 复制为 .env 后修改值（.env 已加入 .gitignore）
# docker-compose 和后端启动都会读取

# === MySQL（docker-compose 使用） ===
MYSQL_HOST_PORT=3307
MYSQL_DATABASE=marca
MYSQL_USER=marca
MYSQL_PASSWORD=marca-dev
MYSQL_ROOT_PASSWORD=rootpassword

# === Spring Boot（marca-backend 启动时使用） ===
DB_URL=jdbc:mysql://localhost:3307/marca?useUnicode=true&characterEncoding=utf8&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Shanghai
DB_USERNAME=marca
DB_PASSWORD=marca-dev

# JWT 密钥至少 32 字符，生产环境务必替换
JWT_SECRET=change-me-in-prod-please-use-at-least-32-chars

# 上传文件目录
UPLOAD_DIR=./uploads
